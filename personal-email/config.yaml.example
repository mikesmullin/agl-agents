# personal-email agent config

# Email provider selection.
# Controls which email CLI backend personal-email uses.
# Supported values: 'google' (default), 'outlook'
#
# email:
#   provider: google

perception:
  # Used when agent.mjs is started with --perception flag.
  # Requires perception-voice server to be running:
  #   cd /path/to/perception-voice && perception-voice serve

  # Path to the perception-voice Unix socket (relative to workspace root, or absolute)
  socket_path: "tmp/whisper/tmp/perception-voice/perception.sock"

  # How long a silence gap (seconds) between utterances triggers a flush of the buffer
  # and an exact-match lookup against word_mappings.
  # Should match whisper's keyboard.word_mapping_pause_threshold_s
  pause_threshold_s: 0.8

  # Map spoken phrases to the text returned to the agent prompt.
  # Matching: case-insensitive, alpha chars only (punctuation ignored).
  # Value is returned verbatim; use \n for Enter.
  word_mappings:
    proceed: "proceed\n"
    skip: "skip\n"
    quit: "quit\n"
    submit: "submit\n"
    erase: "erase\n"
    yes: "yes\n"
    no: "no\n"
    merge: "merge\n"
    refresh: "refresh\n"
    reload: "reload\n"

# Optional folder purpose annotations for gmail labels discovered from google-email.
# Live Gmail labels remain the source of truth; this file adds human-meaningful descriptions.
#
# Example:
# google_email:
#   labels:
#     "Example Label": short description of what belongs in this folder

# Journal memory tuning.
# Controls recommendation confidence gating and re-index behavior.
#
# journal:
#   confidence_threshold: 60    # below this %, 'proceed' is blocked and operator must give explicit instruction
#   reindex_relevance_min: 50   # minimum confidence for Stage 1 relevance filter to include an entry
#   git_auto_commit: true       # auto-commit journal writes to git (requires git in PATH)