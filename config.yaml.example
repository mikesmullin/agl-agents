# Email provider selection.
# Controls which email CLI backend personal-email uses.
# Supported values: 'google' (default), 'outlook'
#
# email:
#   provider: google

# Optional folder purpose annotations for gmail labels discovered from google-email.
# Live Gmail labels remain the source of truth; this file adds human-meaningful descriptions.
#
# Example:
# google_email:
#   labels:
#     "Example Label": short description of what belongs in this folder